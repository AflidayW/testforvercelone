{
  "version": 2,
  "name": "express-products-vercel",
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/swagger.json",
      "dest": "src/index.ts"
    },
    {
      "src": "/api(.*)",
      "dest": "src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ]
}